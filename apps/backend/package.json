{
	"name": "backend",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./contracts": {
			"types": "./src/contracts.ts",
			"default": "./src/contracts.ts"
		}
	},
	"scripts": {
		"dev": "tsx watch src/node.ts",
		"deploy": "wrangler deploy --minify",
		"cf-typegen": "node ../../scripts/cf-typegen.mjs",
		"build": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
