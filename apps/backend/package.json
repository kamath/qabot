		"@octokit/request-error": "^7.1.0",
		"@octokit/rest": "^22.0.1",
		"@smithery/api": "^0.49.0",
		"@workos-inc/node": "^8.3.1",
		"agentmail": "^0.2.17",
		"ai": "^6.0.116",
		"blakejs": "^1.2.1",
		"drizzle-orm": "^0.45.1",
		"fflate": "^0.8.2",
		"hono": "^4.11.9",
		"hono-openapi": "^1.1.2",
		"jose": "^6.1.3",
		"postgres": "^3.4.5",
		"posthog-node": "^4.4.0",
		"tweetnacl": "^1.0.3",
		"zod": "^4.3.6",
		"zod-openapi": "^5.4.6"
	},
	"devDependencies": {
