{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "backend",
	"main": "src/index.ts",
	"compatibility_date": "2026-02-12",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true,
		"logs": {
			"enabled": true,
			"invocation_logs": true
		}
	},
	"rules": [
		{
			"type": "Text",
			"globs": ["**/*.md", "**/*.yml", "**/*.flamecast"],
			"fallthrough": false
		}
	],
	"env": {
		"preview": {}
	}
}
