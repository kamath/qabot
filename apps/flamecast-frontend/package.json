{
	"name": "hono-fs",
	"private": true,
	"type": "module",
	"scripts": {
		"dev:vite": "vite",
		"dev:cf": "wrangler dev --port 5173 --inspector-port 5174",
		"dev": "pnpm run dev:vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"deploy": "wrangler deploy",
		"cf-typegen": "node ../../scripts/cf-typegen.mjs",
		"check": "biome check",
		"check-types": "tsc --noEmit",
		"fmt": "biome check --write --unsafe",
		"secrets:pull": "infisical export --path=/flamecast --env=dev --format=dotenv > .env",
		"secrets:push": "infisical secrets set --file=.env --path=/flamecast --env=dev"
	},
