{
	"name": "flamecast-backend",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev --port 6970 --inspector-port 6971",
		"deploy": "wrangler deploy --minify",
		"cf-typegen": "node ../../scripts/cf-typegen.mjs",
		"secrets:pull": "infisical export --path=/apps/flamecast --env=dev --format=dotenv > .env",
		"secrets:push": "infisical secrets set --file=.env --path=/apps/flamecast --env=dev",
		"build": "pnpm -r --filter '@flamecast/*' build && tsc --noEmit",
		"openapi:generate": "node --import tsx/esm --import ./scripts/text-loader.mjs scripts/generate-openapi.ts",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@flamecast/api-schemas": "workspace:*",
		"@flamecast/auth": "workspace:*",
		"@flamecast/db": "workspace:*",
		"@flamecast/utils": "workspace:*",
		"@hono/standard-validator": "^0.2.2",
		"@hono/swagger-ui": "^0.5.3",
		"@octokit/plugin-throttling": "^11.0.3",
		"@octokit/request-error": "^7.1.0",
		"@octokit/rest": "^22.0.1",
		"@smithery/api": "^0.49.0",
		"@workos-inc/node": "^8.3.1",
		"agentmail": "^0.2.17",
		"blakejs": "^1.2.1",
		"drizzle-orm": "^0.45.1",
		"fflate": "^0.8.2",
		"hono": "^4.11.9",
		"hono-openapi": "^1.1.2",
		"jose": "^6.1.3",
		"postgres": "^3.4.5",
		"posthog-node": "^4.4.0",
		"tweetnacl": "^1.0.3",
		"zod": "^4.3.6",
		"zod-openapi": "^5.4.6"
	},
	"devDependencies": {
		"@types/libsodium-wrappers": "^0.8.2",
		"@types/node": "^25.2.3",
		"tsx": "^4.19.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18",
		"wrangler": "^4.4.0"
	}
}
