/**
 * Commit workflow outputs (user outputs, execution log, FULL_EXECUTION_LOG.md, RESULT.md) to the repo.
 *
 * Env vars:
 *   WORKFLOW_RUN_ID – GitHub Actions run ID of the triggering workflow
 *   RUNNER_TEMP     – GitHub Actions runner temp directory
 */

import { existsSync, mkdirSync, cpSync, readFileSync, writeFileSync, readdirSync } from "node:fs";
import { join } from "node:path";

const runId = process.env.WORKFLOW_RUN_ID;
const runnerTemp = process.env.RUNNER_TEMP;

if (!runId || !runnerTemp) {
  console.error("Missing required env: WORKFLOW_RUN_ID or RUNNER_TEMP");
  process.exit(1);
}

const outputsDir = `runs/${runId}/outputs`;
mkdirSync(outputsDir, { recursive: true });

// Copy user outputs
const userOutputsDir = join(runnerTemp, "flamecast-user-outputs");
if (existsSync(userOutputsDir) && readdirSync(userOutputsDir).length > 0) {
  cpSync(userOutputsDir, outputsDir, { recursive: true });
  console.log(`Copied user outputs to ${outputsDir}`);
}

// Copy execution log
const execLogSrc = join(runnerTemp, "flamecast-execution-log", "claude-execution-output.json");
if (existsSync(execLogSrc)) {
  cpSync(execLogSrc, join(outputsDir, "claude-execution-output.json"));
  console.log("Copied execution log");
}

function normalizeSummaryContent(content: string) {
  const normalized = content.replace(/\r\n/g, "\n").trim();
  if (!normalized) return "";

  // Some runs can produce exact duplicated summaries (same document repeated).
  // Collapse that pattern so the stored log is a single copy.
  for (let copies = 2; copies <= 4; copies += 1) {
    if (normalized.length % copies !== 0) continue;
    const segmentLength = normalized.length / copies;
    const segment = normalized.slice(0, segmentLength);
    if (segment.repeat(copies) === normalized) {
      return `${segment.trimEnd()}\n`;
    }
  }

  return `${normalized}\n`;
}

// Copy summary as FULL_EXECUTION_LOG.md
const summaryFile = join(runnerTemp, "flamecast-summary", "summary.md");
if (existsSync(summaryFile)) {
  const summaryContent = readFileSync(summaryFile, "utf-8");
  writeFileSync(join(outputsDir, "FULL_EXECUTION_LOG.md"), normalizeSummaryContent(summaryContent));
} else {
  writeFileSync(
    join(outputsDir, "FULL_EXECUTION_LOG.md"),
    `No summary available for run ${runId}.\n`,
  );
}

// Generate RESULT.md from execution log
const execLogDest = join(outputsDir, "claude-execution-output.json");
if (existsSync(execLogDest)) {
  try {
    const entries = JSON.parse(readFileSync(execLogDest, "utf-8"));
    const lastResult = entries[entries.length - 1]?.result ?? "";
    writeFileSync(join(outputsDir, "RESULT.md"), lastResult);
    console.log("Generated RESULT.md from execution log");
  } catch (err) {
    console.error("Failed to generate RESULT.md:", err);
  }
}

function run(cmd: string, args: string[]) {
  const result = Bun.spawnSync([cmd, ...args], { stdout: "inherit", stderr: "inherit" });
  if (result.exitCode !== 0) {
    throw new Error(`${cmd} ${args.join(" ")} exited with ${result.exitCode}`);
  }
}

run("git", ["config", "user.name", "github-actions[bot]"]);
run("git", ["config", "user.email", "github-actions[bot]@users.noreply.github.com"]);
run("git", ["add", `runs/${runId}/`]);

const diffResult = Bun.spawnSync(["git", "diff", "--cached", "--quiet"]);
if (diffResult.exitCode === 0) {
  console.log("No changes to commit");
  process.exit(0);
}

run("git", ["commit", "-m", `Add output for run ${runId}`]);
run("git", ["push"]);
