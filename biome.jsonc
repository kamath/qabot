{
	"$schema": "https://biomejs.dev/schemas/2.3.3/schema.json",
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!**/dist",
			"!**/pnpm-lock.yaml",
			"!**/node_modules",
			"!**/worker-configuration.d.ts",
			"!**/routeTree.gen.ts",
			"!.claude"
		]
	},
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"defaultBranch": "main",
		"useIgnoreFile": true
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineEnding": "lf",
		"lineWidth": 80,
		"attributePosition": "auto"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"useSemanticElements": "off",
				"noSvgWithoutTitle": "off",
				"useKeyWithClickEvents": "off",
				"useButtonType": "off",
				"noStaticElementInteractions": "off",
				"noAutofocus": "off",
				"noLabelWithoutControl": "off"
			},
			"correctness": {
				"noUnusedImports": "warn",
				"useExhaustiveDependencies": "off",
				"useHookAtTopLevel": "off",
				"noUnusedVariables": "warn",
				"noUnusedFunctionParameters": "warn"
			},
			"complexity": {
				"noForEach": "off",
				"noUselessSwitchCase": "off",
				"noUselessUndefinedInitialization": "off"
			},
			"security": {
				"noDangerouslySetInnerHtml": "warn",
				"noBlankTarget": "warn"
			},
			"style": {
				"noUnusedTemplateLiteral": "off",
				"noUselessElse": "off",
				"noNonNullAssertion": "off",
				"noParameterAssign": "error",
				"useAsConstAssertion": "error",
				"useSelfClosingElements": "error"
			},
			"suspicious": {
				"noExplicitAny": "warn",
				"noConfusingVoidType": "off",
				"noArrayIndexKey": "off"
			}
		}
	},
	"javascript": {
		"jsxRuntime": "reactClassic",
		"formatter": {
			"jsxQuoteStyle": "double",
			"quoteProperties": "asNeeded",
			"trailingCommas": "all",
			"semicolons": "asNeeded",
			"arrowParentheses": "asNeeded",
			"bracketSpacing": true,
			"bracketSameLine": false,
			"quoteStyle": "double",
			"attributePosition": "auto"
		}
	},
	"json": {
		"formatter": {
			"enabled": true,
			"trailingCommas": "none"
		},
		"parser": {
			"allowComments": true,
			"allowTrailingCommas": false
		}
	},
	"css": {
		"formatter": {
			"enabled": false
		},
		"linter": {
			"enabled": false
		},
		"parser": {
			"cssModules": false,
			"tailwindDirectives": true
		}
	},
	"overrides": [
		{
			"includes": ["**/__tests__/**", "**/*.test.*", "**/*.spec.*"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		}
	],
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "off"
			}
		}
	}
}
